# ============================================================
# AI Website Builder — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# In production, set this to your deployed frontend URL
# CLIENT_ORIGIN=https://your-app.vercel.app

# ─── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Backend only — NEVER expose to client

# ─── AWS Bedrock (LLM Provider) ───────────────────────────
# IAM user must have bedrock:InvokeModelWithResponseStream permission
AWS_ACCESS_KEY_ID=                # Backend only — NEVER expose to client
AWS_SECRET_ACCESS_KEY=            # Backend only — NEVER expose to client
AWS_REGION=ap-southeast-2         # Region where your Bedrock model is enabled
MODEL_ID=amazon.nova-pro-v1:0    # Override to use a different Bedrock model

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10        # Max LLM generations per user per window
RATE_LIMIT_WINDOW_MS=60000        # Window size in milliseconds (60s default)

# ─── Client (Vite — must be prefixed with VITE_) ──────────
# These are safe to expose to the browser
VITE_API_URL=http://localhost:5000/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
