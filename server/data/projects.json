    "id": 1,
    "prompt": "Build a saas website for the startup company\n",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Modern SaaS Startup</title>\n    <style>\n        :root {\n            --primary-color: #635BFF;\n            --secondary-color: #34D399;\n            --text-color: #333;\n            --background-color: #F9F9F9;\n            --card-background: rgba(255, 255, 255, 0.1);\n            --card-hover: rgba(255, 255, 255, 0.2);\n            --border-radius: 12px;\n            --box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            --transition: all 0.3s ease;\n            --font-family: 'Arial', sans-serif;\n            --spacing: 20px;\n        }\n        body {\n            margin: 0;\n            font-family: var(--font-family);\n            background-color: var(--background-color);\n            color: var(--text-color);\n        }\n        .navbar {\n            position: sticky;\n            top: 0;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: var(--spacing);\n            background-color: var(--primary-color);\n            color: white;\n            z-index: 1000;\n        }\n       .navbar a {\n            color: white;\n            text-decoration: none;\n            margin: 0 var(--spacing);\n        }\n       .navbar .cta-button {\n            background-color: var(--secondary-color);\n            padding: 10px 20px;\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            transition: var(--transition);\n        }\n       .navbar .cta-button:hover {\n            background-color: darken(var(--secondary-color), 10%);\n        }\n       .hero {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background: linear-gradient(135deg, #635BFF, #34D399);\n            color: white;\n            text-align: center;\n            padding: var(--spacing);\n        }\n       .hero h1 {\n            font-size: 3rem;\n            margin-bottom: var(--spacing);\n        }\n       .hero p {\n            font-size: 1.25rem;\n            margin-bottom: var(--spacing);\n        }\n       .hero .cta-buttons {\n            display: flex;\n            gap: var(--spacing);\n        }\n        .hero .cta-buttons a {\n            padding: 10px 20px;\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            transition: var(--transition);\n        }\n        .hero.cta-buttons.primary-cta {\n            background-color: white;\n            color: var(--primary-color);\n        }\n       .hero.cta-buttons .secondary-cta {\n            background-color: var(--secondary-color);\n            color: white;\n        }\n       .hero.cta-buttons a:hover {\n            opacity: 0.8;\n        }\n       .section {\n            padding: var(--spacing);\n        }\n       .features,.benefits,.testimonials {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: var(--spacing);\n        }\n        .card {\n            background: var(--card-background);\n            padding: var(--spacing);\n            border-radius: var(--border-radius);\n            box-shadow: var(--box-shadow);\n            transition: var(--transition);\n        }\n        .card:hover {\n            background: var(--card-hover);\n        }\n       .faq {\n            display: grid;\n            gap: var(--spacing);\n        }\n       .faq-item {\n            border: 1px solid rgba(0, 0, 0, 0.1);\n            border-radius: var(--border-radius);\n            overflow: hidden;\n        }\n       .faq-item .question {\n            background-color: var(--primary-color);\n            color: white;\n            padding: var(--spacing);\n            cursor: pointer;\n        }\n       .faq-item .answer {\n            display: none;\n            padding: var(--spacing);\n            background-color: var(--background-color);\n        }\n       .faq-item.active.answer {\n            display: block;\n        }\n       .contact {\n            text-align: center;\n            padding: var(--spacing);\n        }\n        .footer {\n            background-color: var(--primary-color);\n            color: white;\n            padding: var(--spacing);\n            text-align: center;\n        }\n        @media (max-width: 768px) {\n            .hero h1 {\n                font-size: 2rem;\n            }\n           .hero p {\n                font-size: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <nav class=\"navbar\">\n        <div class=\"logo\">SaaS Startup</div>\n        <div class=\"nav-links\">\n            <a href=\"#features\">Features</a>\n            <a href=\"#benefits\">Benefits</a>\n            <a href=\"#testimonials\">Testimonials</a>\n            <a href=\"#faq\">FAQ</a>\n            <a href=\"#contact\">Contact</a>\n        </div>\n        <a href=\"#contact\" class=\"cta-button\">Get Started</a>\n    </nav>\n    <section class=\"hero\" id=\"hero\">\n        <h1>Welcome to Our SaaS Platform</h1>\n        <p>Elevate your business with our cutting-edge solutions.</p>\n        <div class=\"cta-buttons\">\n            <a href=\"#contact\" class=\"primary-cta\">Get Started</a>\n            <a href=\"#features\" class=\"secondary-cta\">Learn More</a>\n        </div>\n    </section>\n    <section class=\"section features\" id=\"features\">\n        <h2>Our Features</h2>\n        <div class=\"card\">Feature 1: Detailed description of the feature.</div>\n        <div class=\"card\">Feature 2: Detailed description of the feature.</div>\n        <div class=\"card\">Feature 3: Detailed description of the feature.</div>\n        <div class=\"card\">Feature 4: Detailed description of the feature.</div>\n        <div class=\"card\">Feature 5: Detailed description of the feature.</div>\n        <div class=\"card\">Feature 6: Detailed description of the feature.</div>\n    </section>\n    <section class=\"section benefits\" id=\"benefits\">\n        <h2>Our Benefits</h2>\n        <div class=\"card\">Benefit 1: Detailed description of the benefit.</div>\n        <div class=\"card\">Benefit 2: Detailed description of the benefit.</div>\n        <div class=\"card\">Benefit 3: Detailed description of the benefit.</div>\n        <div class=\"card\">Benefit 4: Detailed description of the benefit.</div>\n    </section>\n    <section class=\"section testimonials\" id=\"testimonials\">\n        <h2>What Our Customers Say</h2>\n        <div class=\"card\">\"This platform has transformed our business!\" - Customer 1</div>\n        <div class=\"card\">\"Excellent service and outstanding results.\" - Customer 2</div>\n        <div class=\"card\">\"Highly recommend for any business looking to scale.\" - Customer 3</div>\n    </section>\n    <section class=\"section faq\" id=\"faq\">\n        <h2>Frequently Asked Questions</h2>\n        <div class=\"faq-item\">\n            <div class=\"question\">What is your pricing model?</div>\n            <div class=\"answer\">We offer flexible pricing plans tailored to your needs.</div>\n        </div>\n        <div class=\"faq-item\">\n            <div class=\"question\">How can I get started?</div>\n            <div class=\"answer\">Sign up for an account and explore our features.</div>\n        </div>\n        <div class=\"faq-item\">\n            <div class=\"question\">What support do you offer?</div>\n            <div class=\"answer\">We provide 24/7 customer support via chat and email.</div>\n        </div>\n        <div class=\"faq-item\">\n            <div class=\"question\">Is there a free trial available?</div>\n            <div class=\"answer\">Yes, we offer a 14-day free trial with full access.</div>\n        </div>\n        <div class=\"faq-item\">\n            <div class=\"question\">Can I cancel my subscription anytime?</div>\n            <div class=\"answer\">Yes, you can cancel your subscription at any time.</div>\n        </div>\n    </section>\n    <section class=\"section contact\" id=\"contact\">\n        <h2>Get in Touch</h2>\n        <p>Have questions? Contact us at <a href=\"mailto:support@saasstartup.com\">support@saasstartup.com</a>.</p>\n    </section>\n    <footer class=\"footer\">\n        <p>&copy; 2024 SaaS Startup. All rights reserved.</p>\n    </footer>\n    <script>\n        document.querySelectorAll('.faq-item .question').forEach(item => {\n            item.addEventListener('click', () => {\n                item.parentElement.classList.toggle('active');\n            });\n        });\n    </script>\n</body>\n</html>",
