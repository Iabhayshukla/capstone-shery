    "prompt": "generate a website for the wine shop\n",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Wine Shop</title>\n    <style>\n        :root {\n            --primary-color: #6a1b9a;\n            --secondary-color: #ffc107;\n            --text-color: #333;\n            --background-color: #f9f9f9;\n            --card-bg-color: #fff;\n            --card-hover-bg-color: #f3f3f3;\n            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            --border-radius: 12px;\n            --spacing: 20px;\n            --font-family: 'Arial', sans-serif;\n            --transition: 0.3s ease-in-out;\n        }\n        body {\n            margin: 0;\n            font-family: var(--font-family);\n            background-color: var(--background-color);\n            color: var(--text-color);\n        }\n        .navbar {\n            position: sticky;\n            top: 0;\n            width: 100%;\n            background-color: var(--primary-color);\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 10px var(--spacing);\n            z-index: 1000;\n        }\n        .navbar a {\n            color: #fff;\n            text-decoration: none;\n            margin: 0 10px;\n            font-weight: bold;\n        }\n       .navbar .cta-btn {\n            background-color: var(--secondary-color);\n            padding: 10px 20px;\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            color: #fff;\n            font-weight: bold;\n            transition: var(--transition);\n        }\n        .navbar .cta-btn:hover {\n            background-color: darken(var(--secondary-color), 10%);\n        }\n       .hero {\n            background: linear-gradient(135deg, #8e2de2, #4a00e0);\n            color: #fff;\n            padding: 100px var(--spacing);\n            text-align: center;\n        }\n        .hero h1 {\n            font-size: 3rem;\n            margin-bottom: 20px;\n        }\n        .hero p {\n            font-size: 1.25rem;\n            margin-bottom: 30px;\n        }\n        .hero.cta-btn {\n            background-color: var(--secondary-color);\n            padding: 15px 30px;\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            color: #fff;\n            font-weight: bold;\n            margin-right: 10px;\n            transition: var(--transition);\n        }\n        .hero.cta-btn:hover {\n            background-color: darken(var(--secondary-color), 10%);\n        }\n       .hero.secondary-btn {\n            background-color: transparent;\n            border: 2px solid #fff;\n            padding: 15px 30px;\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            color: #fff;\n            font-weight: bold;\n            transition: var(--transition);\n        }\n       .hero.secondary-btn:hover {\n            background-color: #fff;\n            color: var(--primary-color);\n        }\n       .section {\n            padding: 60px var(--spacing);\n        }\n        .features,.benefits,.testimonials {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: var(--spacing);\n        }\n        .card {\n            background-color: var(--card-bg-color);\n            padding: 20px;\n            border-radius: var(--border-radius);\n            box-shadow: var(--shadow);\n            transition: var(--transition);\n        }\n        .card:hover {\n            background-color: var(--card-hover-bg-color);\n        }\n       .card h3 {\n            margin-bottom: 10px;\n        }\n       .card p {\n            color: #666;\n        }\n       .faq {\n            display: grid;\n            gap: var(--spacing);\n        }\n        .faq-item {\n            background-color: var(--card-bg-color);\n            padding: 20px;\n            border-radius: var(--border-radius);\n            box-shadow: var(--shadow);\n            cursor: pointer;\n            transition: var(--transition);\n        }\n       .faq-item:hover {\n            background-color: var(--card-hover-bg-color);\n        }\n       .faq-item.question {\n            font-weight: bold;\n            margin-bottom: 10px;\n        }\n       .faq-item .answer {\n            display: none;\n            color: #666;\n        }\n       .faq-item.active.answer {\n            display: block;\n        }\n       .footer {\n            background-color: var(--primary-color);\n            color: #fff;\n            padding: 30px var(--spacing);\n            text-align: center;\n        }\n        @media (max-width: 768px) {\n           .hero h1 {\n                font-size: 2rem;\n            }\n           .hero p {\n                font-size: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <nav class=\"navbar\">\n        <a href=\"#hero\">Home</a>\n        <a href=\"#features\">Features</a>\n        <a href=\"#benefits\">Benefits</a>\n        <a href=\"#testimonials\">Testimonials</a>\n        <a href=\"#faq\">FAQ</a>\n        <a href=\"#contact\">Contact</a>\n        <a class=\"cta-btn\" href=\"#contact\">Get Started</a>\n    </nav>\n    <section id=\"hero\" class=\"hero\">\n        <h1>Discover Exquisite Wines</h1>\n        <p>Explore our collection of premium wines from around the world.</p>\n        <a class=\"cta-btn\" href=\"#contact\">Shop Now</a>\n        <a class=\"secondary-btn\" href=\"#features\">Learn More</a>\n    </section>\n    <section id=\"features\" class=\"section\">\n        <h2>Our Features</h2>\n        <div class=\"features\">\n            <div class=\"card\">\n                <h3>Wide Selection</h3>\n                <p>Choose from a vast array of wines from different regions.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Expert Recommendations</h3>\n                <p>Get personalized wine suggestions from our experts.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Secure Payments</h3>\n                <p>Enjoy safe and secure transactions with our payment gateway.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Fast Delivery</h3>\n                <p>Get your wines delivered quickly with our reliable shipping service.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Customer Support</h3>\n                <p>Our dedicated support team is here to assist you.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Wine Tasting Events</h3>\n                <p>Join our exclusive wine tasting events and learn more about your favorite wines.</p>\n            </div>\n        </div>\n    </section>\n    <section id=\"benefits\" class=\"section\">\n        <h2>Our Benefits</h2>\n        <div class=\"benefits\">\n            <div class=\"card\">\n                <h3>Quality Assurance</h3>\n                <p>We ensure the highest quality standards for all our wines.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Affordable Prices</h3>\n                <p>Enjoy great wines at competitive prices.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Easy Returns</h3>\n                <p>Not satisfied with your purchase? We offer hassle-free returns.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Loyalty Rewards</h3>\n                <p>Earn rewards and discounts with our loyalty program.</p>\n            </div>\n        </div>\n    </section>\n    <section id=\"testimonials\" class=\"section\">\n        <h2>Customer Testimonials</h2>\n        <div class=\"testimonials\">\n            <div class=\"card\">\n                <p>\"Exceptional wine selection and excellent customer service!\"</p>\n                <h4>- John Doe</h4>\n            </div>\n            <div class=\"card\">\n                <p>\"I love the variety and quality of wines available here.\"</p>\n                <h4>- Jane Smith</h4>\n            </div>\n            <div class=\"card\">\n                <p>\"Fast delivery and secure payments make shopping here a breeze.\"</p>\n                <h4>- Mike Johnson</h4>\n            </div>\n        </div>\n    </section>\n    <section id=\"faq\" class=\"section\">\n        <h2>Frequently Asked Questions</h2>\n        <div class=\"faq\">\n            <div class=\"faq-item\" onclick=\"this.classList.toggle('active')\">\n                <div class=\"question\">How do I place an order?</div>\n                <div class=\"answer\">You can place an order by selecting your desired wines and proceeding to checkout.</div>\n            </div>\n            <div class=\"faq-item\" onclick=\"this.classList.toggle('active')\">\n                <div class=\"question\">What payment methods do you accept?</div>\n                <div class=\"answer\">We accept credit cards, debit cards, and PayPal.</div>\n            </div>\n            <div class=\"faq-item\" onclick=\"this.classList.toggle('active')\">\n                <div class=\"question\">What is your return policy?</div>\n                <div class=\"answer\">We offer a 30-day return policy for unsatisfied purchases.</div>\n            </div>\n            <div class=\"faq-item\" onclick=\"this.classList.toggle('active')\">\n                <div class=\"question\">Do you offer international shipping?</div>\n                <div class=\"answer\">Yes, we offer international shipping to select countries.</div>\n            </div>\n            <div class=\"faq-item\" onclick=\"this.classList.toggle('active')\">\n                <div class=\"question\">How can I contact customer support?</div>\n                <div class=\"answer\">You can contact our customer support team via email or phone.</div>\n            </div>\n        </div>\n    </section>\n    <section id=\"contact\" class=\"section\">\n        <h2>Contact Us</h2>\n        <p>Have questions or need assistance? Reach out to us!</p>\n        <form>\n            <input type=\"text\" placeholder=\"Your Name\" required><br>\n            <input type=\"email\" placeholder=\"Your Email\" required><br>\n            <textarea placeholder=\"Your Message\" required></textarea><br>\n            <button type=\"submit\">Send Message</button>\n        </form>\n    </section>\n    <footer class=\"footer\">\n        <p>&copy; 2024 Wine Shop. All rights reserved.</p>\n    </footer>\n</body>\n</html>",
