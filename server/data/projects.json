    "prompt": "build a restaurant website \n",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Restaurant Delight</title>\n    <style>\n        :root {\n            --primary-color: #6a1b9a;\n            --secondary-color: #ffca28;\n            --background-color: #f9f9f9;\n            --text-color: #333;\n            --font-family: 'Arial', sans-serif;\n            --font-size-base: 16px;\n            --font-size-lg: 20px;\n            --font-size-xl: 24px;\n            --font-size-xxl: 32px;\n            --spacing-sm: 8px;\n            --spacing-md: 16px;\n            --spacing-lg: 24px;\n            --border-radius: 12px;\n            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            --transition: all 0.3s ease;\n        }\n        body {\n            font-family: var(--font-family);\n            color: var(--text-color);\n            background-color: var(--background-color);\n            margin: 0;\n            padding: 0;\n        }\n       .navbar {\n            position: sticky;\n            top: 0;\n            background-color: var(--primary-color);\n            color: white;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: var(--spacing-md);\n            z-index: 1000;\n        }\n       .navbar a {\n            color: white;\n            text-decoration: none;\n            margin: 0 var(--spacing-sm);\n        }\n       .navbar a:hover {\n            opacity: 0.8;\n        }\n        .navbar .cta-button {\n            background-color: var(--secondary-color);\n            padding: var(--spacing-sm) var(--spacing-md);\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            transition: var(--transition);\n        }\n       .navbar.cta-button:hover {\n            background-color: darken(var(--secondary-color), 10%);\n        }\n       .hero {\n            background: linear-gradient(135deg, #6a1b9a, #ffca28);\n            color: white;\n            padding: var(--spacing-lg);\n            text-align: center;\n        }\n       .hero h1 {\n            font-size: var(--font-size-xxl);\n            margin-bottom: var(--spacing-sm);\n        }\n       .hero p {\n            font-size: var(--font-size-lg);\n            margin-bottom: var(--spacing-md);\n        }\n       .hero.cta-button {\n            background-color: white;\n            color: var(--primary-color);\n            padding: var(--spacing-sm) var(--spacing-md);\n            border-radius: var(--border-radius);\n            text-decoration: none;\n            margin: 0 var(--spacing-sm);\n            transition: var(--transition);\n        }\n        .hero.cta-button:hover {\n            background-color: lighten(white, 10%);\n        }\n       .features,.benefits,.testimonials,.faq,.contact {\n            padding: var(--spacing-lg);\n            text-align: center;\n        }\n       .features h2,.benefits h2,.testimonials h2,.faq h2,.contact h2 {\n            font-size: var(--font-size-xl);\n            margin-bottom: var(--spacing-md);\n        }\n       .card {\n            background-color: rgba(255, 255, 255, 0.8);\n            border-radius: var(--border-radius);\n            padding: var(--spacing-md);\n            margin: var(--spacing-md);\n            box-shadow: var(--shadow);\n            transition: var(--transition);\n        }\n        .card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.1);\n        }\n       .faq.accordion {\n            background-color: white;\n            border-radius: var(--border-radius);\n            margin-bottom: var(--spacing-md);\n            box-shadow: var(--shadow);\n        }\n       .faq.accordion-header {\n            padding: var(--spacing-md);\n            cursor: pointer;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .faq.accordion-content {\n            padding: var(--spacing-md);\n            display: none;\n        }\n        footer {\n            background-color: var(--primary-color);\n            color: white;\n            padding: var(--spacing-lg);\n            text-align: center;\n        }\n        @media (min-width: 768px) {\n           .features.card,.benefits.card {\n                display: inline-block;\n                width: calc(33.333% - var(--spacing-md));\n            }\n            .testimonials.card {\n                width: calc(33.333% - var(--spacing-md));\n            }\n        }\n    </style>\n</head>\n<body>\n    <nav class=\"navbar\">\n        <div>\n            <a href=\"#hero\">Home</a>\n            <a href=\"#features\">Features</a>\n            <a href=\"#benefits\">Benefits</a>\n            <a href=\"#testimonials\">Testimonials</a>\n            <a href=\"#faq\">FAQ</a>\n            <a href=\"#contact\">Contact</a>\n        </div>\n        <a href=\"#contact\" class=\"cta-button\">Reserve a Table</a>\n    </nav>\n    <section id=\"hero\" class=\"hero\">\n        <h1>Welcome to Restaurant Delight</h1>\n        <p>Experience the finest dining with us. Savor every moment.</p>\n        <a href=\"#contact\" class=\"cta-button\">Reserve a Table</a>\n        <a href=\"#features\" class=\"cta-button\">Learn More</a>\n    </section>\n    <section id=\"features\" class=\"features\">\n        <h2>Our Features</h2>\n        <div class=\"card\">Exquisite Menu</div>\n        <div class=\"card\">Ambitious Ambiance</div>\n        <div class=\"card\">Exceptional Service</div>\n        <div class=\"card\">Private Dining Rooms</div>\n        <div class=\"card\">Live Music Events</div>\n        <div class=\"card\">Weekend Brunches</div>\n    </section>\n    <section id=\"benefits\" class=\"benefits\">\n        <h2>Our Benefits</h2>\n        <div class=\"card\">Unmatched Quality</div>\n        <div class=\"card\">Customer Satisfaction</div>\n        <div class=\"card\">Convenient Location</div>\n        <div class=\"card\">Family-Friendly</div>\n    </section>\n    <section id=\"testimonials\" class=\"testimonials\">\n        <h2>What Our Customers Say</h2>\n        <div class=\"card\">\"Best dining experience ever!\" - John Doe</div>\n        <div class=\"card\">\"Amazing food and service!\" - Jane Smith</div>\n        <div class=\"card\">\"A must-visit restaurant!\" - Mike Johnson</div>\n    </section>\n    <section id=\"faq\" class=\"faq\">\n        <h2>Frequently Asked Questions</h2>\n        <div class=\"accordion\">\n            <div class=\"accordion-header\">What are your opening hours?</div>\n            <div class=\"accordion-content\">We are open from 11 AM to 10 PM every day.</div>\n        </div>\n        <div class=\"accordion\">\n            <div class=\"accordion-header\">Do you offer vegetarian options?</div>\n            <div class=\"accordion-content\">Yes, we have a variety of vegetarian dishes.</div>\n        </div>\n        <div class=\"accordion\">\n            <div class=\"accordion-header\">Is there a dress code?</div>\n            <div class=\"accordion-content\">Smart casual is preferred.</div>\n        </div>\n        <div class=\"accordion\">\n            <div class=\"accordion-header\">Can I make a reservation?</div>\n            <div class=\"accordion-content\">Yes, please contact us to make a reservation.</div>\n        </div>\n        <div class=\"accordion\">\n            <div class=\"accordion-header\">Do you have a loyalty program?</div>\n            <div class=\"accordion-content\">Yes, join our loyalty program for exclusive benefits.</div>\n        </div>\n    </section>\n    <section id=\"contact\" class=\"contact\">\n        <h2>Contact Us</h2>\n        <p>Email: info@restaurantdelight.com</p>\n        <p>Phone: +123 456 7890</p>\n        <p>Address: 1234 Gourmet St, Flavor Town</p>\n    </section>\n    <footer>\n        <p>&copy; 2024 Restaurant Delight. All rights reserved.</p>\n    </footer>\n    <script>\n        document.querySelectorAll('.accordion').forEach(item => {\n            item.addEventListener('click', event => {\n                const content = item.querySelector('.accordion-content');\n                content.style.display = content.style.display === 'none'? 'block' : 'none';\n            });\n        });\n    </script>\n</body>\n</html>",
