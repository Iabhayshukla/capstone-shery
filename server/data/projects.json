    "html": "html <!DOCTYPE html> <html lang=\"en\"> <head>     <meta charset=\"UTF-8\">     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">     <title>Elite Gym</title>     <style>         :root {             --primary: #1e3a8a;             --secondary: #6366f1;             --accent: #f97316;             --background: #f3f4f6;             --surface: #ffffff;             --text: #1f2937;             --radius: 12px;             --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);         }         body {             margin: 0;             font-family: 'Inter', sans-serif;             background-color: var(--background);             color: var(--text);         }         .sticky-nav {             position: sticky;             top: 0;             background-color: var(--surface);             box-shadow: var(--shadow);             z-index: 1000;         }         .nav-bar {             display: flex;             justify-content: space-between;             align-items: center;             padding: 1rem 2rem;         }        .nav-logo {             font-size: 1.5rem;             font-weight: bold;         }        .nav-links {             display: flex;             gap: 1rem;         }        .nav-links a {             text-decoration: none;             color: var(--text);             font-weight: 500;         }         .cta-button {             background-color: var(--primary);             color: var(--surface);             padding: 0.5rem 1rem;             border-radius: var(--radius);             text-decoration: none;             font-weight: 600;             transition: background-color 0.3s;         }         .cta-button:hover {             background-color: var(--secondary);         }        .hero {             display: flex;             flex-direction: column;             justify-content: center;             align-items: flex-start;             height: 100vh;             padding: 4rem 2rem;             background: linear-gradient(135deg, #e0f2fe, #e0e7ff);             color: var(--text);         }        .hero h1 {             font-size: 3rem;             margin-bottom: 1rem;         }        .hero p {             font-size: 1.25rem;             margin-bottom: 2rem;         }        .hero .cta {             display: flex;             gap: 1rem;         }        .hero .cta a {             text-decoration: none;         }         .features {             display: grid;             grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));             gap: 2rem;             padding: 4rem 2rem;             text-align: center;         }        .features.card {             background-color: var(--surface);             padding: 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);             transition: transform 0.3s;         }         .features.card:hover {             transform: translateY(-5px);         }        .benefits {             display: grid;             grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));             gap: 2rem;             padding: 4rem 2rem;             text-align: center;             background-color: var(--background);         }        .benefits.card {             background-color: var(--surface);             padding: 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);         }         .statistics {             display: grid;             grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));             gap: 2rem;             padding: 4rem 2rem;             text-align: center;             background-color: var(--surface);         }        .statistics.card {             padding: 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);         }        .testimonials {             display: flex;             flex-direction: column;             gap: 2rem;             padding: 4rem 2rem;             text-align: center;             background-color: var(--background);         }         .testimonials .card {             background-color: var(--surface);             padding: 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);         }        .pricing {             display: grid;             grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));             gap: 2rem;             padding: 4rem 2rem;             text-align: center;         }         .pricing.tier {             background-color: var(--surface);             padding: 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);         }        .pricing.recommended {             border: 2px solid var(--primary);         }        .faq {             display: flex;             flex-direction: column;             gap: 1rem;             padding: 4rem 2rem;             background-color: var(--background);         }         .faq .item {             background-color: var(--surface);             padding: 1rem 2rem;             border-radius: var(--radius);             box-shadow: var(--shadow);             cursor: pointer;         }        .faq.item.active {             background-color: var(--primary);             color: var(--surface);         }        .contact {             padding: 4rem 2rem;             background-color: var(--surface);         }        .contact form {             display: flex;             flex-direction: column;             gap: 1rem;         }        .contact input,.contact textarea {             padding: 1rem;             border-radius: var(--radius);             border: 1px solid var(--text);         }        .footer {             display: flex;             flex-direction: column;             gap: 1rem;             padding: 2rem;             background-color: var(--background);             color: var(--text);         }        .footer .column {             display: flex;             flex-direction: column;             gap: 0.5rem;         }         @media (max-width: 768px) {             .hero {                 height: auto;                 padding: 2rem;             }            .hero h1 {                 font-size: 2rem;             }             .hero p {                 font-size: 1rem;             }         }     </style> </head> <body>     <header class=\"sticky-nav\">         <nav class=\"nav-bar\">             <div class=\"nav-logo\">Elite Gym</div>             <div class=\"nav-links\">                 <a href=\"#features\">Features</a>                 <a href=\"#benefits\">Benefits</a>                 <a href=\"#statistics\">Statistics</a>                 <a href=\"#testimonials\">Testimonials</a>                 <a href=\"#pricing\">Pricing</a>                 <a href=\"#faq\">FAQ</a>                 <a href=\"#contact\">Contact</a>             </div>             <a href=\"#cta\" class=\"cta-button\">Join Now</a>         </nav>     </header>     <section class=\"hero\" id=\"hero\">         <h1>Transform Your Body</h1>         <p>Join Elite Gym and start your fitness journey today.</p>         <div class=\"cta\">             <a href=\"#cta\" class=\"cta-button\">Join Now</a>             <a href=\"#features\" class=\"cta-link\">Learn More</a>         </div>     </section>     <section class=\"features\" id=\"features\">         <div class=\"card\">             <h2>State-of-the-Art Equipment</h2>             <p>Access to the latest fitness machines and equipment.</p>         </div>         <div class=\"card\">             <h2>Expert Trainers</h2>             <p>Personalized training sessions with certified professionals.</p>         </div>         <div class=\"card\">             <h2>Flexible Hours</h2>             <p>24/7 access to the gym, so you can work out on your schedule.</p>         </div>         <div class=\"card\">             <h2>Group Classes</h2>             <p>Variety of group fitness classes to choose from.</p>         </div>         ",
